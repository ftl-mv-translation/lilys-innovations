#: src-en/data/text_tooltips.xml.append:31
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"tooltip_lily_ablative_armor_disabled\"]"
msgstr "再生無効。"

#: src-en/data/text_tooltips.xml.append:32
msgid ""
"data/text_tooltips.xml.append$//text[@name=\"tooltip_lily_ablative_armor_level\"]"
